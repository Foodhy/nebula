# ──────────────────────────────────────────────────────────────
# Nébula · .env.example
# Copy to .env and fill in. NEVER commit the real .env.
# In production, these values come from Vault/SOPS, not a file.
# ──────────────────────────────────────────────────────────────

# General
NEBULA_ENV=development            # development | staging | production
NEBULA_DOMAIN=localhost

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nebula
POSTGRES_USER=nebula
POSTGRES_PASSWORD=changeme        # dev only; in prod from Vault

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (object storage)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=changeme
MINIO_SECRET_KEY=changeme
MINIO_REGION=us-east-1
# Built-in KMS key for SSE-S3 (name:base64-32B). Dev only; prod via Vault/KES.
MINIO_KMS_SECRET_KEY=nebula-key:3vqzQAmnI3kE8OHoSX1pALI7AJqe8OTykbIPGtf9uG8=
MINIO_KMS_KEY_NAME=nebula-key

# App DB role (non-superuser; RLS applies). Services connect as this.
NEBULA_APP_DB_USER=nebula_app
NEBULA_APP_DB_PASSWORD=changeme

# NATS (event bus)
NATS_URL=nats://localhost:4222

# Meilisearch
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=changeme

# Atlas / Keycloak (identity)
OIDC_ISSUER_URL=http://localhost:8080/realms/nebula
OIDC_CLIENT_ID=nebula-apps
OIDC_CLIENT_SECRET=changeme
KEYCLOAK_ADMIN=admin              # dev bootstrap admin (Keycloak console)
KEYCLOAK_ADMIN_PASSWORD=admin     # dev only; in prod from Vault
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=nebula

# Atlas BFF
ATLAS_PORT=4000

# Vega storage service
VEGA_PORT=4010

# Vega BFF (frontend-for-backend) + web
VEGA_BFF_PORT=4011
VEGA_STORAGE_URL=http://localhost:4010
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_BFF_URL=http://localhost:4011

# Helios (dashboard) BFF + web
HELIOS_BFF_PORT=4020
NEXT_PUBLIC_HELIOS_BFF_URL=http://localhost:4020

# Vault (secrets / encryption keys) — dev can use dev mode
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=changeme

# JWT (if a service signs its own tokens; prefer delegating to Atlas)
JWT_AUDIENCE=nebula

# Observability (Órbita)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
