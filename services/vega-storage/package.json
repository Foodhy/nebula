{
  "name": "@nebula/vega-storage",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src",
    "test": "vitest run",
    "migrate": "node-pg-migrate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@nebula/config": "workspace:*",
    "@nebula/db": "workspace:*",
    "@nebula/nucleo-auth": "workspace:*",
    "@nebula/nucleo-events": "workspace:*",
    "@nebula/observability": "workspace:*",
    "@nebula/security": "workspace:*",
    "@nebula/types": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nebula/tsconfig": "workspace:*",
    "@testcontainers/postgresql": "^10.16.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "node-pg-migrate": "^7.9.0",
    "testcontainers": "^10.16.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
