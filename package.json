{
  "name": "nebula",
  "version": "0.0.0",
  "private": true,
  "description": "Nébula — self-hosted, modular, dockerized productivity suite",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
